# Supabase
CFD_SUPABASE_URL=https://your-project.supabase.co
CFD_SUPABASE_KEY=your-supabase-anon-key

# Scopus API (optional, needed for Scopus data source)
CFD_SCOPUS_API_KEY=your-scopus-api-key

# Analysis thresholds (defaults shown)
# CFD_MIN_PUBLICATIONS=10
# CFD_MIN_CITATIONS=20
# CFD_MIN_H_INDEX=3

# Indicator thresholds (defaults shown)
# CFD_MCR_THRESHOLD=0.3
# CFD_SCR_WARN_THRESHOLD=0.25
# CFD_SCR_HIGH_THRESHOLD=0.40
# CFD_CB_THRESHOLD=0.30

# Cache
# CFD_CACHE_TTL_DAYS=7

# Rate limiting
# CFD_OPENALEX_REQUESTS_PER_SECOND=9
# CFD_SCOPUS_REQUESTS_PER_SECOND=5

# Localization
# CFD_DEFAULT_LANGUAGE=ua
